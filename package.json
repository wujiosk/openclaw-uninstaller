{
  "name": "openclaw-uninstaller",
  "version": "0.3.2",
  "description": "A local Windows GUI tool for scanning, backing up and uninstalling OpenClaw.",
  "type": "module",
  "bin": {
    "openclaw-uninstaller": "./src/index.mjs"
  },
  "scripts": {
    "start": "node ./src/index.mjs",
    "start:webui": "node ./src/webui-server.mjs",
    "start:uninstaller": "node ./src/webui-server.mjs",
    "check": "node ./src/index.mjs",
    "build:exe": "node ./scripts/build-exe.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "pkg": {
    "scripts": [
      "src/**/*.mjs"
    ],
    "assets": [
      "README.md",
      "webui/**/*"
    ],
    "outputPath": "dist"
  }
}
